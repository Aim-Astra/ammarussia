  border-left: 3px solid var(--gold);
  border-radius: 0 8px 8px 0;
}
.about__quote blockquote {
  font-family: 'Playfair Display', serif; font-style: italic;
  font-size: 0.95rem; color: var(--text-muted); line-height: 1.7;
