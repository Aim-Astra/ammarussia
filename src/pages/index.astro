.section-label--light { color: rgba(212,168,67,0.8); }
.ornament--light::before,
.ornament--light::after { background: linear-gradient(to right, transparent, rgba(212,168,67,0.4), transparent); }
.ornament--light .ornament-icon { color: rgba(212,168,67,0.6); }

/* ===== ABOUT ===== */
.about {
  display: grid; grid-template-columns: 1fr 420px; gap: 80px; align-items: start;
}
.about__lead {
  font-size: 1.08rem; margin-bottom: 20px; color: var(--text-dark); line-height: 1.75;
}
