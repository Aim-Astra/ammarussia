---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'AMMA Russia — All-Moscow Malayalee Association';
const pageDesc  = 'All-Moscow Malayalee Association (AMMA Russia). Preserving Kerala culture, celebrating Onam, and uniting the diaspora community in Moscow since 2015.';
---

<Layout title={pageTitle} description={pageDesc} lang="en">

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- NAVBAR                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <header class="navbar" id="navbar">
    <div class="container">
      <div class="navbar__inner">
        <a href="/" class="navbar__logo">
          <img src="/images/amma-logo.png" alt="AMMA Russia" class="navbar__logo-img" />
          <div class="navbar__logo-text">
            AMMA Russia
            <span>All-Moscow Malayalee Association</span>
          </div>
        </a>
        <nav class="navbar__nav" id="navLinks">
          <a href="#about" class="navbar__link">About Onam</a>
          <a href="#event" class="navbar__link">Program</a>
          <a href="#artist" class="navbar__link">Artist</a>
          <a href="/committee" class="navbar__link">Committee</a>
          <a href="/contact" class="navbar__link">Contact</a>
        </nav>
        <button class="navbar__burger" id="burgerBtn" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HERO                                                          -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <img
        src="/images/hero-kerala.jpg"
        alt="Kerala temple gopuram at golden sunrise"
        class="hero__img"
        loading="eager"
        decoding="async"
      />
      <div class="hero__overlay"></div>
      <div class="hero__pattern"></div>
    </div>

    <div class="container hero__content">
      <div class="hero__eyebrow reveal">
        <span class="hero__eyebrow-dot"></span>
        Embassy of India · Moscow · AMMA Russia
      </div>

      <h1 class="hero__title reveal reveal-delay-1">
        The Great<br />
        <em class="hero__title-em">Onam</em><br />
        Celebration
      </h1>

      <p class="hero__subtitle reveal reveal-delay-2">
        Join us for the most cherished festival of Kerala — a vibrant celebration of harvest,
        culture, and the timeless spirit of unity, hosted by the All-Moscow Malayalee Association.
      </p>

      <div class="hero__actions reveal reveal-delay-3">
        <a href="#event" class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          View Program
        </a>
        <a href="/committee" class="btn btn--ghost">Meet the Team</a>
      </div>

      <div class="hero__meta reveal reveal-delay-4">
        <div class="hero__meta-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Saturday, 13 September 2025
        </div>
        <div class="hero__meta-sep">·</div>
        <div class="hero__meta-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          Embassy of India, Moscow
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll">
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ABOUT ONAM                                                     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section" id="about">
    <div class="container">
      <div class="about__grid">

        <div class="about__text">
          <div class="section-label reveal">The Festival</div>
          <h2 class="section-title reveal reveal-delay-1">A 4,000-Year-Old<br />Celebration of the Harvest</h2>

          <p class="about__lead reveal reveal-delay-2">
            Onam is the grand harvest festival of Kerala, celebrated with immense pride and joy
            by Malayalees across the world. It commemorates the annual homecoming of the mythical
            King Mahabali, whose reign symbolized equality, prosperity, and justice for all.
          </p>

          <p class="about__body reveal reveal-delay-3">
            The festival spans ten days, filled with flower rangoli competitions (Pookalam),
            classical Kathakali performances, Tiger-play (Puli Kali), boat races (Vallamkali),
            and the legendary Onasadya — a feast of 26 traditional dishes served on a banana leaf.
          </p>

          <div class="about__stats reveal reveal-delay-4">
            <div class="about__stat">
              <span class="about__stat-num">4,000</span>
              <span class="about__stat-label">Years of tradition</span>
            </div>
            <div class="about__stat">
              <span class="about__stat-num">26</span>
              <span class="about__stat-label">Dishes at Onasadya</span>
            </div>
            <div class="about__stat">
              <span class="about__stat-num">10</span>
              <span class="about__stat-label">Days of celebration</span>
            </div>
          </div>
        </div>

        <div class="about__visual reveal">
          <div class="about__img-frame">
            <img
              src="/images/pookalam-mmx.jpg"
              alt="Traditional Onam Pookalam rangoli"
              class="about__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="about__img-caption">
            Traditional Pookalam — flower rangoli created during Onam
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- EVENT PROGRAM                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" id="event">
    <div class="container">
      <div class="section-header">
        <div class="section-label reveal">Onam 2025</div>
        <h2 class="section-title reveal reveal-delay-1">Celebration Program</h2>
        <p class="section-subtitle reveal reveal-delay-2">
          A day of cultural performances, classical arts, and the grand Onasadya feast —
          all under one roof at the Embassy of India in Moscow.
        </p>
      </div>

      <div class="timeline">

        <div class="timeline__item reveal">
          <div class="timeline__time">
            <span>10:00</span>
            <span>AM</span>
          </div>
          <div class="timeline__connector">
            <div class="timeline__dot"></div>
            <div class="timeline__line"></div>
          </div>
          <div class="timeline__card">
            <h3 class="timeline__title">Guest Reception & Welcome</h3>
            <p class="timeline__desc">
              Guests arrive at the Embassy of India, Moscow. Traditional welcome with
              a garland ceremony and warm Malayalee hospitality.
            </p>
          </div>
        </div>

        <div class="timeline__item reveal reveal-delay-1">
          <div class="timeline__time">
            <span>11:00</span>
            <span>AM</span>
          </div>
          <div class="timeline__connector">
            <div class="timeline__dot"></div>
            <div class="timeline__line"></div>
          </div>
          <div class="timeline__card">
            <h3 class="timeline__title">Inaugural Ceremony</h3>
            <p class="timeline__desc">
              Official opening of the Onam celebration with the national anthems of India
              and Russia, followed by a lamp-lighting ceremony and opening remarks.
            </p>
          </div>
        </div>

        <div class="timeline__item reveal reveal-delay-2">
          <div class="timeline__time">
            <span>12:00</span>
            <span>PM</span>
          </div>
          <div class="timeline__connector">
            <div class="timeline__dot"></div>
            <div class="timeline__line"></div>
          </div>
          <div class="timeline__card">
            <h3 class="timeline__title">Cultural Evening — "This is Vidhu Prathap"</h3>
            <p class="timeline__desc">
              A solo classical Indian music concert featuring renowned artist
              <strong>Vidhu Prathap</strong>, accompanied by traditional percussion.
            </p>
          </div>
        </div>

        <div class="timeline__item reveal reveal-delay-3">
          <div class="timeline__time">
            <span>14:00</span>
            <span>PM</span>
          </div>
          <div class="timeline__connector">
            <div class="timeline__dot"></div>
            <div class="timeline__line"></div>
          </div>
          <div class="timeline__card">
            <h3 class="timeline__title">Cultural Performances</h3>
            <p class="timeline__desc">
              Classical and folk performances including Thiruvathira Kali, Pookalam
              competition, and a showcase of Kerala's rich artistic heritage.
            </p>
          </div>
        </div>

        <div class="timeline__item reveal reveal-delay-4">
          <div class="timeline__time">
            <span>15:30</span>
            <span>PM</span>
          </div>
          <div class="timeline__connector">
            <div class="timeline__dot timeline__dot--last"></div>
          </div>
          <div class="timeline__card">
            <h3 class="timeline__title">Grand Onasadya Feast</h3>
            <p class="timeline__desc">
              The legendary 26-dish Onasadya served on a banana leaf — the
              centerpiece of every Onam celebration. Vegetarian, traditional recipes.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- FEATURED ARTIST                                               -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section" id="artist">
    <div class="container">
      <div class="artist__grid">

        <div class="artist__visual reveal">
          <div class="artist__img-wrap">
            <img
              src="/images/vidhu-prathap.jpg"
              alt="Vidhu Prathap — Classical Indian Music Artist"
              class="artist__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="artist__social">
            <a href="https://www.instagram.com/amma4_moscow" target="_blank" rel="noopener" aria-label="Instagram" class="artist__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </a>
            <a href="https://t.me/moscowamma" target="_blank" rel="noopener" aria-label="Telegram" class="artist__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="artist__text">
          <div class="section-label reveal">Featured Artist</div>
          <h2 class="artist__name reveal reveal-delay-1">Vidhu Prathap</h2>
          <p class="artist__role reveal reveal-delay-2">Solo Classical Indian Music Artist</p>

          <div class="artist__quote reveal reveal-delay-3">
            <p>
              "Onam is not just a festival — it is a feeling. The moment the first Pookalam
              appears on the ground and the aroma of the Onasadya fills the air, we are
              transported back to the land of Kerala, no matter where in the world we are."
            </p>
          </div>

          <p class="artist__bio reveal reveal-delay-4">
            A distinguished vocalist and percussionist, Vidhu Prathap has performed at major
            cultural events across India and internationally, bringing the rich traditions of
            Carnatic music to global audiences. His performance at AMMA Russia's Onam
            celebration is a highlight of the annual calendar.
          </p>

          <div class="artist__stats reveal reveal-delay-4">
            <div class="artist__stat">
              <span class="artist__stat-num">15+</span>
              <span class="artist__stat-label">Years performing</span>
            </div>
            <div class="artist__stat">
              <span class="artist__stat-num">50+</span>
              <span class="artist__stat-label">Cities toured</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- COMMITTEE PREVIEW                                             -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" id="committee">
    <div class="container">
      <div class="section-header">
        <div class="section-label reveal">The People</div>
        <h2 class="section-title reveal reveal-delay-1">Our Community</h2>
        <p class="section-subtitle reveal reveal-delay-2">
          The dedicated members of AMMA Russia who work tirelessly to preserve
          and celebrate Kerala's rich cultural heritage in Moscow.
        </p>
      </div>

      <div class="committee-preview reveal">
        <img
          src="/images/committee-group.jpg"
          alt="AMMA Russia Committee Group Photo"
          class="committee-preview__img"
          loading="lazy"
          decoding="async"
        />
        <div class="committee-preview__overlay">
          <a href="/committee" class="btn btn--primary">
            View Full Committee
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CTA                                                           -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="cta">
    <div class="cta__bg">
      <img
        src="/images/pookalam-hero.jpg"
        alt="Onam celebration"
        class="cta__img"
        loading="lazy"
        decoding="async"
      />
      <div class="cta__overlay"></div>
    </div>
    <div class="container cta__content">
      <h2 class="cta__title reveal">Be Part of the Celebration</h2>
      <p class="cta__subtitle reveal reveal-delay-1">
        Whether you are Malayalee or simply love Kerala's culture — you are welcome.
        Join the All-Moscow Malayalee Association and experience the warmth of our community.
      </p>
      <div class="cta__actions reveal reveal-delay-2">
        <a href="/contact" class="btn btn--primary">Get in Touch</a>
        <a href="/committee" class="btn btn--ghost">Our Team</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- FOOTER                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container">
      <div class="footer__grid">
        <div>
          <a href="/" class="navbar__logo" style="text-decoration:none; display:inline-flex; align-items:center; gap:10px;">
            <img src="/images/amma-logo.png" alt="AMMA Russia" style="height:40px; width:auto; border-radius:6px;" />
            <div class="navbar__logo-text">AMMA Russia<span>All-Moscow Malayalee Association</span></div>
          </a>
          <p class="footer__brand-text">
            Uniting the Kerala diaspora in Moscow since 2015. Celebrating our heritage,
            sharing our culture, and building a vibrant Malayalee community in Russia.
          </p>
        </div>
        <div>
          <div class="footer__title">Navigate</div>
          <ul class="footer__list">
            <li><a href="#about">About Onam</a></li>
            <li><a href="#event">Program</a></li>
            <li><a href="#artist">Artist</a></li>
            <li><a href="/committee">Committee</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <div class="footer__title">Contact</div>
          <ul class="footer__list">
            <li><a href="mailto:ammarussia@mail.ru">ammarussia@mail.ru</a></li>
            <li>Dr. Binu Paniker</li>
            <li>+7 985 130 0221</li>
            <li>Moscow, Russia</li>
          </ul>
        </div>
        <div>
          <div class="footer__title">Follow Us</div>
          <div class="footer__social">
            <a href="https://t.me/moscowamma" target="_blank" rel="noopener" aria-label="Telegram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/amma4_moscow" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </a>
            <a href="https://www.facebook.com/share/1B9PzjDi7b/" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="footer__bottom">
        <p class="footer__copy">
          &copy; 2015&ndash;2026 All-Moscow Malayalee Association (AMMA Russia). All rights reserved.
        </p>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ── Hero Section ──────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(28,25,23,0.75) 0%,
      rgba(28,25,23,0.55) 50%,
      rgba(185,28,28,0.3) 100%
    );
  }
  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 80%, rgba(212,160,23,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(185,28,28,0.06) 0%, transparent 50%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: 120px;
