/* Pookalam art */
.pookalam-art {
  position: relative; width: 300px; height: 300px; margin: 0 auto;
  display: flex; align-items: center; justify-content: center;
}
.pookalam-art__outer {
  position: absolute; inset: 0; border-radius: 50%;
  background: radial-gradient(circle, rgba(212,168,67,0.08) 0%, transparent 70%);
  border: 1px solid rgba(212,168,67,0.1);
}
.pookalam-art__ring {
  position: absolute; border-radius: 50%; border: 1.5px solid var(--gold);
}
.pookalam-art__ring--1 { width: 300px; height: 300px; opacity: 0.2; }
.pookalam-art__ring--2 { width: 210px; height: 210px; opacity: 0.4; animation: pookalam-rotate 25s linear infinite; }
.pookalam-art__ring--3 { width: 130px; height: 130px; opacity: 0.65; animation: pookalam-rotate 18s linear infinite reverse; }
.pookalam-art__dots { position: absolute; inset: 0; }
.pookalam-art__dot {
  position: absolute; width: 12px; height: 12px;
  background: var(--crimson); border-radius: 50%;
  top: 50%; left: 50%;
  transform: rotate(calc(var(--i) * (360deg / var(--total)))) translateX(110px) rotate(calc(-1 * var(--i) * (360deg / var(--total))));
  opacity: 0.55;
}
.pookalam-art__center {
  width: 60px; height: 60px; background: var(--gold);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  z-index: 1; animation: pulse-glow 3s ease-in-out infinite;
}
